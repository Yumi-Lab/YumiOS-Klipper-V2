#!/usr/bin/env bash
# YumiOS-Klipper-V2 — Project config (vanilla CustomPiOS)
# This file is sourced by build_dist. Keep it self-contained.
# shellcheck enable=require-variable-braces

get_version() {
    local ver
    ver="$(realpath "$( dirname -- "${BASH_SOURCE[0]}")"/version)"
    if [ -f "${ver}" ]; then
        cat "${ver}"
        return
    fi
    echo "unknown"
}

get_img_name() {
    local -a types
    types=(zip 7z xz)
    if [ -n "${DIST_PATH}" ]; then
        for i in "${types[@]}"; do
            find "${DIST_PATH}/image/" -type f -name "*.${i}" -printf "%p\n"
        done
    fi
    if [ -z "${DIST_PATH}" ]; then
        echo ""
    fi
}

DIST_VERSION="$(get_version)"
BASE_ZIP_IMG="$(get_img_name)"
DIST_NAME="YumiOS"

export DIST_NAME
export DIST_VERSION
export BASE_ZIP_IMG

# Base User
BASE_ADD_USER="yes"
BASE_USER="pi"
BASE_USER_PASSWORD="yumi"

# Needed while building for non rpi sbc
BASE_DISTRO="armbian"
BASE_IMAGE_RASPBIAN="no"

# partition resizing
BASE_ROOT_PARTITION="2"
BASE_IMAGE_ENLARGEROOT=6000
BASE_IMAGE_RESIZEROOT=600
BASE_BOOT_MOUNT_PATH="/boot/"
BASE_RELEASE_COMPRESS=no

# Architecture
BASE_ARCH="armhf"

# OS naming
BASE_OS_CODENAME="bookworm"
BASE_OS_VERSION="debian12"

# Image base (SmartPi-armbian)
DOWNLOAD_URL_CHECKSUM="https://github.com/Yumi-Lab/SmartPi-armbian/releases/download/v1.7.0/Yumi-smartpi1-bookworm-debian12-server-2026-04-23-0753.img.xz.sha256"
DOWNLOAD_URL_IMAGE="https://github.com/Yumi-Lab/SmartPi-armbian/releases/download/v1.7.0/Yumi-smartpi1-bookworm-debian12-server-2026-04-23-0753.img.xz"

# Modules — YumiOS Klipper stack for SmartPi One
MODULES="base(udev_fix,armbian(armbian_net,yumios,klipper,is_req_preinstall,moonraker,mainsail,timelapse,klipperscreen,crowsnest,usb-automount,cpu_governor,mcu-rpi,tmc-autotune))"

export BASE_ADD_USER
export BASE_USER
export BASE_USER_PASSWORD
export BASE_DISTRO
export BASE_IMAGE_RASPBIAN
export BASE_ROOT_PARTITION
export BASE_IMAGE_ENLARGEROOT
export BASE_IMAGE_RESIZEROOT
export BASE_BOOT_MOUNT_PATH
export BASE_RELEASE_COMPRESS
export BASE_ARCH
export BASE_OS_CODENAME
export BASE_OS_VERSION
export DOWNLOAD_URL_CHECKSUM
export DOWNLOAD_URL_IMAGE
export MODULES
