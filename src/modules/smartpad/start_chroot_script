#!/usr/bin/env bash
#### SmartPad / SmartPi ONE — Yumi-specific tweaks
####
#### This module handles all Yumi-Lab customizations:
#### - Plymouth boot theme
#### - YUMI_SYNC
#### - moonraker-yumi-lab plugin
#### - yumi-config install.sh
#### - YUMI_PLR (power loss recovery)
#### - Webcam fix service
#### - Moonraker allowed services
#### - Firstboot wizard (only on boards with display)
####
#### Works for both SmartPad (arm64, display) and SmartPi ONE (armhf, headless)

# shellcheck enable=require-variable-braces
set -Ee

# shellcheck disable=SC1091
source /common.sh
install_cleanup_trap

### Helper func
is_board_type() {
    local board releasefile
    board=""
    releasefile="/etc/armbian-release"
    if [[ -f "${releasefile}" ]]; then
        board="$(grep "BOARD=" "${releasefile}" | cut -d'=' -f2)"
    fi
    echo "${board}"
}

has_display() {
    # SmartPad and SmartPi ONE are the same hardware.
    # SmartPad = with display, SmartPi ONE = headless.
    # Since we can't detect display at build time (chroot), always enable
    # the firstboot wizard — it will detect display at runtime.
    echo "1"
}

echo_green "Apply Yumi-Lab specific patches..."

## Step 0: Install dependencies
# shellcheck disable=SC2086
check_install_pkgs ${SMARTPAD_DEPS}

## Step 1: Unpack filesystem overlay
unpack /filesystem/root /

## Step 2: Board-specific hardware config
if [[ "$(is_board_type)" == "smartpad" ]]; then
    echo_green "Enable Serial and SPI interface on SmartPad..."
    echo "overlays=spi-spidev uart1 uart2" >> "${SMARTPAD_CONFIG_TXT_FILE}"
    echo "param_spidev_spi_bus=1" >> "${SMARTPAD_CONFIG_TXT_FILE}"
    echo_green "Enable Serial and SPI interface on SmartPad... DONE!"
fi

## Step 3: Plymouth boot theme
echo_green "Install Yumi Lab Plymouth theme..."
pushd "/home/${BASE_USER}" &>/dev/null || exit 1

install_plymouth_theme() {
    local src dest
    dest="/usr/share/plymouth/themes/"
    src="/home/${BASE_USER}/$(basename "${SMARTPAD_PLYMOUTH_REPO/.git/}")"
    src="${src}/pack_2/hexagon_alt"
    if [[ -d "${src}" ]]; then
        cp -r "${src}" "${dest}"
        plymouth-set-default-theme "${SMARTPAD_PLYMOUTH_THEME}"
        echo_green "Plymouth theme set to ${SMARTPAD_PLYMOUTH_THEME}"
    else
        echo_green "Plymouth theme dir not found, skipping"
    fi
}

sudo -u "${BASE_USER}" git clone "${SMARTPAD_PLYMOUTH_REPO}"
install_plymouth_theme
popd &>/dev/null || exit 1
echo_green "Install Yumi Lab Plymouth theme... [DONE]"

## Step 4: YUMI_SYNC
echo_green "Install YUMI_SYNC ..."
pushd "/home/${BASE_USER}" &>/dev/null || exit 1
sudo -u "${BASE_USER}" git clone https://github.com/Yumi-Lab/YUMI_SYNC.git
pushd YUMI_SYNC &>/dev/null || exit 1
make install
git checkout . 2>/dev/null || true
git config --global --add safe.directory "/home/${BASE_USER}/YUMI_SYNC"
popd &>/dev/null || exit 1
popd &>/dev/null || exit 1
chown -R "${BASE_USER}:${BASE_USER}" "/home/${BASE_USER}/YUMI_SYNC"
echo_green "Install YUMI_SYNC ... [DONE]"

## Step 5a: Install Janus (WebRTC for moonraker-yumi-lab/obico)
## Available via apt on Bookworm, pre-built .deb for Trixie
if apt-cache show janus &>/dev/null 2>&1; then
    echo_green "Installing Janus from apt ..."
    check_install_pkgs janus
else
    echo_green "Janus not in apt, installing pre-built .deb from GitHub Releases ..."
    curl -sL -o /tmp/janus-gateway.deb \
        https://github.com/Yumi-Lab/moonraker-yumi-lab/releases/download/janus-v1.2.4-trixie-armhf/janus-gateway_1.2.4_armhf.deb
    dpkg -i /tmp/janus-gateway.deb || true
    apt-get install -f -y
    rm -f /tmp/janus-gateway.deb
fi
echo_green "Install Janus ... [DONE]"

## Step 5b: moonraker-yumi-lab plugin
echo_green "Install moonraker-yumi-lab ..."
pushd "/home/${BASE_USER}" &>/dev/null || exit 1
unpack /filesystem/home/"${BASE_USER}" /home/"${BASE_USER}" "${BASE_USER}"
sudo -u "${BASE_USER}" git clone https://github.com/Yumi-Lab/moonraker-yumi-lab.git
pushd moonraker-yumi-lab &>/dev/null || exit 1
chmod +x ./install.sh
sudo -u "${BASE_USER}" ./install.sh \
    -C "/home/${BASE_USER}/printer_data/config/moonraker.conf" \
    -p 7125 -H 127.0.0.1 \
    -l "/home/${BASE_USER}/printer_data/logs" \
    -L -S "https://app.yumi-lab.com"
popd &>/dev/null || exit 1
popd &>/dev/null || exit 1
# moonraker-obico-update.cfg is created by install.sh — keep it as-is (V1 behavior)
echo_green "Install moonraker-yumi-lab ... [DONE]"

## Step 6: yumi-config install script
echo_green "Install yumi-config ..."
pushd "/home/${BASE_USER}" &>/dev/null || exit 1
# yumi-config is already cloned by the yumios module
if [[ -d "/home/${BASE_USER}/yumi-config" ]]; then
    pushd yumi-config &>/dev/null || exit 1
    chmod +x ./install.sh
    ./install.sh
    popd &>/dev/null || exit 1
else
    echo_green "yumi-config not found, skipping install.sh"
fi
popd &>/dev/null || exit 1
echo_green "Install yumi-config ... [DONE]"

## Step 7: YUMI_PLR (Power Loss Recovery)
echo_green "Install YUMI_PLR ..."
pushd "/home/${BASE_USER}" &>/dev/null || exit 1
sudo -u "${BASE_USER}" git clone https://github.com/Yumi-Lab/YUMI_PLR.git
pushd YUMI_PLR &>/dev/null || exit 1
chmod +x ./install.sh
./install.sh
popd &>/dev/null || exit 1
popd &>/dev/null || exit 1
echo_green "Install YUMI_PLR ... [DONE]"

## Step 8: Fix printer_data permissions
chmod 775 -R "/home/${BASE_USER}/printer_data/"
chown -R "${BASE_USER}:${BASE_USER}" "/home/${BASE_USER}/printer_data/"

## Step 9: Webcam fix service
echo_green "Install fix-webcam service ..."

SCRIPT_PATH="/usr/local/bin/fix-webcam.sh"
SERVICE_PATH="/etc/systemd/system/fix-webcam.service"

cat << 'WEBCAM_SCRIPT' > "${SCRIPT_PATH}"
#!/bin/bash
sleep 3
[ -L /dev/webcam ] && rm -f /dev/webcam
for dev in /dev/video*; do
    if v4l2-ctl --device="$dev" --all &>/dev/null; then
        ln -s "$dev" /dev/webcam
        exit 0
    fi
done
exit 1
WEBCAM_SCRIPT
chmod +x "${SCRIPT_PATH}"

cat << 'WEBCAM_SERVICE' > "${SERVICE_PATH}"
[Unit]
Description=Fix Webcam Symlink
After=multi-user.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/fix-webcam.sh
RemainAfterExit=true

[Install]
WantedBy=multi-user.target
WEBCAM_SERVICE

systemctl_if_exists enable fix-webcam.service
echo_green "Install fix-webcam service ... [DONE]"

## Step 10: Moonraker allowed services
echo_green "Configure moonraker allowed services ..."
FILE="/home/${BASE_USER}/printer_data/moonraker.asvc"
SERVICES=("KlipperScreen" "YUMI_SYNC" "crowsnest")

for SERVICE in "${SERVICES[@]}"; do
    grep -qxF "${SERVICE}" "${FILE}" 2>/dev/null || echo "${SERVICE}" >> "${FILE}"
done
echo_green "Configure moonraker allowed services ... [DONE]"

## Step 11: Firstboot wizard (only on display boards)
if [[ "$(has_display)" == "1" ]]; then
    echo_green "Setup firstboot wizard (display detected)..."
    systemctl_if_exists disable KlipperScreen.service
    chmod +x /usr/local/bin/firstboot
    systemctl_if_exists enable firstboot.service
    echo_green "Setup firstboot wizard ... [DONE]"
else
    echo_green "Headless board — skipping firstboot wizard, enabling KlipperScreen directly"
    # On headless boards, KlipperScreen stays enabled (VNC/remote access)
    # No firstboot wizard needed
    rm -f /usr/local/bin/firstboot 2>/dev/null || true
    rm -f /etc/systemd/system/firstboot.service 2>/dev/null || true
    rm -f /.firstboot 2>/dev/null || true
fi

echo_green "Apply Yumi-Lab specific patches... [ALL DONE]"
