#!/usr/bin/env bash
#### firstboot actions — YumiOS SmartPad/SmartPi ONE
####
#### Runs once at first boot:
#### - Applies HDMI rotation (180°) for SmartPad display
#### - Enables Plymouth boot logo
#### - Generates initramfs
#### - Enables KlipperScreen
#### - Disables itself
#### - Reboots

set -e

echo "Starting firstboot script..."

DIALOGRC=/.firstboot
export DIALOGRC
DIALOG="$(which dialog)"
DIALOG=("${DIALOG}" --backtitle "YumiOS First Boot Setup")
RESOLUTION=(20 60)

# Change active tty for dialog display
chvt 2

# Stop KlipperScreen if running (it would conflict with dialog on TTY)
if [[ "$(systemctl is-active KlipperScreen.service 2>/dev/null)" = "active" ]]; then
    systemctl stop KlipperScreen.service &>/dev/null
fi

welcome_msg() {
    cat << EOF

Hello dear YUMI user,
Please be patient, we have to prepare your first start!

    *** DO NOT UNPLUG DEVICE OR DISRUPT THIS PROCESS! ***

Some steps may take several minutes. Stay patient please.
The device will reboot after exiting ...
Continuing setup in ...
EOF
}

reboot_msg() {
    cat << EOF

Your device will be restarted in 5 seconds...

Thank you for being patient and have fun with your
    *** YUMI SmartPad ***

EOF
}

apply_hdmi_rotation() {
    # Rotate HDMI display 180° for SmartPad (connector position requires it)
    # This adds fbcon rotation + KlipperScreen display rotation
    local envfile="/boot/armbianEnv.txt"

    if [[ -f "${envfile}" ]]; then
        # Add kernel framebuffer rotation (180° = rotate:2)
        if ! grep -q "extraargs=.*fbcon=rotate:2" "${envfile}"; then
            if grep -q "^extraargs=" "${envfile}"; then
                sed -i 's/^extraargs=\(.*\)/extraargs=\1 fbcon=rotate:2/' "${envfile}"
            else
                echo "extraargs=fbcon=rotate:2" >> "${envfile}"
            fi
        fi
    fi

    # Xorg rotation for KlipperScreen (X11 display server)
    mkdir -p /etc/X11/xorg.conf.d/
    cat > /etc/X11/xorg.conf.d/90-smartpad-rotate.conf << 'XCONF'
Section "Monitor"
    Identifier "HDMI-1"
    Option "Rotate" "inverted"
EndSection
XCONF
}

gen_initramfs() {
    update-initramfs -u &>/dev/null
}

enable_ks() {
    systemctl --quiet enable KlipperScreen.service &>/dev/null
}

disable_firstboot() {
    systemctl --quiet disable firstboot.service &>/dev/null || true
    rm -f /etc/systemd/system/firstboot.service &>/dev/null || true
}

# Set large font for readability on HDMI display
setfont /usr/share/consolefonts/Lat15-TerminusBold20x10.psf.gz 2>/dev/null || true

# Welcome msg
"${DIALOG[@]}" --clear --title "YumiOS First Boot" \
    --no-cancel --no-ok --pause "$(welcome_msg)" "${RESOLUTION[@]}" 15

# Step 1: Apply HDMI rotation
apply_hdmi_rotation
sleep 1 | "${DIALOG[@]}" --clear --gauge "Applying display rotation ..." "${RESOLUTION[@]}" 20

# Step 2: Enable boot logo
if [[ -f /boot/armbianEnv.txt ]]; then
    sed -i 's/bootlogo=false/bootlogo=true/' /boot/armbianEnv.txt
fi
sleep 1 | "${DIALOG[@]}" --clear --gauge "Enabling boot logo ..." "${RESOLUTION[@]}" 40

# Step 3: Generate initramfs (includes plymouth + fbcon rotation)
gen_initramfs
sleep 1 | "${DIALOG[@]}" --clear --gauge "Generating initramfs ..." "${RESOLUTION[@]}" 60

# Step 4: Enable KlipperScreen
enable_ks
sleep 1 | "${DIALOG[@]}" --clear --gauge "Enabling KlipperScreen ..." "${RESOLUTION[@]}" 80

# Step 5: Disable firstboot service
disable_firstboot
sleep 1 | "${DIALOG[@]}" --clear --gauge "Finalizing ..." "${RESOLUTION[@]}" 100

# Show reboot screen
"${DIALOG[@]}" --clear --title "Setup Complete" \
    --no-cancel --no-ok --pause "$(reboot_msg)" "${RESOLUTION[@]}" 5

# Cleanup
rm -f /.firstboot

# Reboot to apply rotation
reboot

exit 0
