# shellcheck enable=require-variable-braces

# Source error handling, leave this in place
set -Ee

# Source CustomPIOS common.sh
# shellcheck disable=SC1091
source /common.sh
install_cleanup_trap

# pip install for Moonraker
apt-get install -y python3-pip python3-venv python3-virtualenv python3-dev \
libopenjp2-7 libopenjp2-7-dev python3-libgpiod curl libcurl4-openssl-dev \
libssl-dev liblmdb-dev libsodium-dev zlib1g-dev libjpeg-dev libpng-dev \
libtiff-dev libfreetype6-dev liblcms2-dev libwebp-dev tcl-dev tk-dev \
packagekit wireless-tools python3-pil

echo_green "Installing Moonraker and enable Moonraker Service ..."

## Force apt update
apt-get update
## Make sure 'git' is installed!
check_install_pkgs git

## Step 1: Move to Home Dir as WorkingDirectory
pushd "/home/${BASE_USER}" &> /dev/null || exit 1

## Step 2: clone moonraker repo
echo_green "Clone moonraker repo ..."
gitclone MOONRAKER_REPO moonraker
chown -R "${BASE_USER}:${BASE_USER}" "/home/${BASE_USER}/moonraker"

## Step 2b: Pre-create moonraker virtualenv and install Pillow from piwheels
## (avoids building Pillow from source on armv7l where PyPI has no wheels)
## NOTE: pip inside the armhf chroot on an aarch64 kernel reports platform as
## linux_aarch64, so it ignores armv7l wheels from piwheels. We download and
## install the wheel manually to bypass platform tagging.
echo_green "Pre-creating moonraker virtualenv and pre-installing Pillow from piwheels ..."
MN_REQ_FILE="/home/${BASE_USER}/moonraker/scripts/moonraker-requirements.txt"
PILLOW_CONSTRAINT=""
if [[ -f "${MN_REQ_FILE}" ]]; then
    PILLOW_CONSTRAINT=$(grep '^pillow' "${MN_REQ_FILE}" | head -n 1)
fi
if [[ -z "${PILLOW_CONSTRAINT}" ]]; then
    PILLOW_CONSTRAINT="pillow>=9.5.0,<=12.1.0"
fi

# piwheels latest compatible version for armv7l
# Detect Python version for correct wheel tag (Bookworm=3.11, Trixie=3.13)
PILLOW_VERSION="12.0.0"
PY_MAJOR_MINOR=$(python3 -c 'import sys; print(f"cp{sys.version_info.major}{sys.version_info.minor}")')
PY_TAG="${PY_MAJOR_MINOR}"
PLATFORM_TAG="linux_armv7l"
WHEEL_NAME="pillow-${PILLOW_VERSION}-${PY_TAG}-${PY_TAG}-${PLATFORM_TAG}.whl"
WHEEL_URL="https://www.piwheels.org/simple/pillow/${WHEEL_NAME}"
echo_green "Detected Python tag: ${PY_TAG} — Pillow wheel: ${WHEEL_NAME}"

# Create TMPDIR with proper permissions before virtualenv
sudo -u "${BASE_USER}" mkdir -p "/home/${BASE_USER}/tmp"

sudo -u "${BASE_USER}" virtualenv -p python3 "/home/${BASE_USER}/moonraker-env"
sudo -u "${BASE_USER}" "/home/${BASE_USER}/moonraker-env/bin/pip" install --upgrade pip setuptools wheel

mkdir -p /tmp/piwheels
echo_green "Downloading precompiled Pillow wheel: ${WHEEL_NAME} ..."
if ! curl -fsSL -o "/tmp/piwheels/${WHEEL_NAME}" "${WHEEL_URL}"; then
    echo_red "Failed to download Pillow wheel from piwheels (${WHEEL_URL})"
    exit 1
fi
sudo -u "${BASE_USER}" "/home/${BASE_USER}/moonraker-env/bin/pip" install "/tmp/piwheels/${WHEEL_NAME}"

# Create constraints file to pin Pillow version and prevent reinstall
echo "pillow==${PILLOW_VERSION}" > /tmp/pillow-constraints.txt

## Step 7: Move to moonraker as working directory
pushd "/home/${BASE_USER}/moonraker" &> /dev/null || exit 1

## Step 8: Run moonraker install routine
echo_green "Launch moonraker install routine ..."
sudo -u "${BASE_USER}" TMPDIR="/home/${BASE_USER}/tmp" PIP_CONSTRAINT="/tmp/pillow-constraints.txt" ./scripts/install-moonraker.sh -s -z -x

## Step 9: Install policykit rules
echo_green "Install moonrakers PolicyKit Rules ..."
sudo -u "${BASE_USER}" ./scripts/set-policykit-rules.sh --root

## Step 10: Leave moonraker
popd &> /dev/null || exit 1

## Step 10b: Cleanup tmp files to free space for subsequent modules
rm -rf /tmp/piwheels /tmp/pillow-constraints.txt
rm -rf "/home/${BASE_USER}/tmp"

## Step 11: leave home dir
popd &> /dev/null || exit 1

## Step 12: Install MainsailOS premade moonraker.conf
echo_green "Copying MainsailOS premade moonraker.conf ..."
unpack /filesystem/home/"${BASE_USER}" /home/"${BASE_USER}" "${BASE_USER}"

## Step 13: Enable moonraker.service
echo_green "Enable moonraker.service ..."
systemctl_if_exists enable moonraker.service

## Finish
echo_green "Installing Moonraker and enable Moonraker Service ... DONE!"
