# shellcheck enable=requires-variable-braces

# Error handling
set -Ee

# shellcheck disable=SC1091
source /common.sh
install_cleanup_trap

mkdir -p /tmp
chmod 1777 /tmp

# Module only Variables
SR_BUILD_PACKAGE_FILE="/tmp/sr_packages.lst"

echo_green "Installing sonar ..."

## Force apt update
apt-get update
## Make sure 'git' is installed!
check_install_pkgs git

## Step 1: Move to Home Dir as WorkingDirectoy
pushd "/home/${BASE_USER}" &> /dev/null || exit 1

## Step 2: clone sonar repo
echo_green "Clone sonar repository ..."
gitclone SONAR_REPO sonar

## Step 3: Set SONAR_DEPS manually
echo_green "Manually defining SONAR_DEPS ..."
SONAR_DEPS="network-manager wireless-tools iw ethtool curl net-tools"

## Step 4: Install packages
echo_green "Install sonar dependencies ..."
# shellcheck disable=SC2086
check_install_pkgs ${SONAR_DEPS}

## Step 5: Move to sonar as working directory
pushd "/home/${BASE_USER}/sonar" &> /dev/null || exit 1

## Step 6: Run sonar install routine
echo_green "Launch sonar install routine ..."
make install || { echo_red "Sonar install failed"; exit 1; }

## Step 7: Leave sonar
popd &> /dev/null || exit 1

## Step 8: Override sonar.conf — enable + tuned for NetworkManager
echo_green "Writing sonar.conf (enabled, 30s interval) ..."
cat <<'SONAREOF' > "/home/${BASE_USER}/printer_data/config/sonar.conf"
[sonar]
enable: true
debug_log: false
persistent_log: false
target: auto
count: 3
interval: 30
restart_threshold: 5
SONAREOF
chown "${BASE_USER}:${BASE_USER}" "/home/${BASE_USER}/printer_data/config/sonar.conf"

## Step 9: NetworkManager WiFi auto-reconnect dispatcher
echo_green "Installing NetworkManager WiFi reconnect dispatcher ..."
cat <<'DISPEOF' > /etc/NetworkManager/dispatcher.d/99-wifi-reconnect
#!/usr/bin/env bash
# Reconnect WiFi automatically when connection drops
# Triggered by NetworkManager on interface state changes

IFACE="$1"
ACTION="$2"

# Only act on WiFi interfaces going down
case "$IFACE" in wlan*|wlp*) ;; *) exit 0 ;; esac

if [ "$ACTION" = "down" ]; then
    logger -t wifi-reconnect "WiFi $IFACE went down, scheduling reconnect ..."
    # Wait a bit then ask NM to re-activate
    (
        sleep 5
        nmcli device connect "$IFACE" 2>/dev/null \
            || nmcli networking off && sleep 2 && nmcli networking on
        logger -t wifi-reconnect "WiFi reconnect attempt done for $IFACE"
    ) &
fi
DISPEOF
chmod 755 /etc/NetworkManager/dispatcher.d/99-wifi-reconnect

## Step 10: Force autoconnect on all future WiFi connections
echo_green "Configuring NetworkManager autoconnect ..."
cat <<'NMEOF' > /etc/NetworkManager/conf.d/wifi-autoconnect.conf
[connection]
# Retry WiFi connection indefinitely (0 = infinite retries)
connection.autoconnect-retries=0
NMEOF

## Step 11: clean packages.lst file
rm -f "${SR_BUILD_PACKAGE_FILE}"

## Step 12: leave home dir
popd &> /dev/null || exit 1

## Step 13: Enable sonar service
echo_green "Enable sonar.service ..."
systemctl_if_exists enable sonar.service

## Finish
echo_green "Installing sonar ... DONE!"
