#!/usr/bin/env bash
#### CPU Governor — set to userspace for Klipper stability
####
#### Dynamic frequency scaling causes Klipper USB/MCU disconnections.
#### Use Armbian's native /etc/default/cpufrequtils to lock governor.
####

# shellcheck enable=require-variable-braces
# shellcheck disable=SC1091
source /common.sh
install_cleanup_trap

echo_green "Setting CPU governor to userspace..."

if [[ -f /etc/default/cpufrequtils ]]; then
    sed -i 's/^GOVERNOR=.*/GOVERNOR=userspace/' /etc/default/cpufrequtils
else
    echo "GOVERNOR=userspace" > /etc/default/cpufrequtils
fi

# Clean up old custom service and script if present
rm -f /etc/systemd/system/set-cpu-freq.service
rm -f /usr/local/bin/set_cpu_freq.sh

echo_green "CPU governor set to userspace ... [DONE]"
